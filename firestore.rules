rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Catálogos públicos (solo lectura autenticada, escritura bloqueada) ────

    match /catalogoBancos/{codigo} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /catalogoCategorias/{categoriaId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /reglasCategorizacionGlobales/{reglaId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /tasasCambio/{fecha} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Datos de usuario: el owner tiene acceso completo a toda su jerarquía ─
    // La validación de integridad de datos es responsabilidad del cliente
    // (parsers + mappers + use cases en Kotlin). Las reglas solo garantizan
    // aislamiento por uid.

    match /usuarios/{uid} {
      allow read, write: if isOwner(uid);

      match /{coleccion}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
