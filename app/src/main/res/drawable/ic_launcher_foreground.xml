<?xml version="1.0" encoding="utf-8"?>
<!--
  FlowTrack launcher icon foreground.
  Reproduces the LogoBox del login: rounded rect (safe-zone 18–90 dp, corner r=16)
  con gradiente radial y el ícono de gráfica encima.
  Viewport 108×108 → safe zone 18–90 → box 72×72 dp.
  Gradient center: 18 + 72×0.20 = 32.4 | radius: 72×1.20 = 86.4
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Rounded-rect background (gradiente radial) ── -->
    <path android:pathData="M34,18 L74,18 Q90,18 90,34 L90,74 Q90,90 74,90 L34,90 Q18,90 18,74 L18,34 Q18,18 34,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32.4"
                android:centerY="32.4"
                android:gradientRadius="86.4">
                <item android:offset="0.00" android:color="#60508AFF"/>
                <item android:offset="0.60" android:color="#9914285A"/>
                <item android:offset="1.00" android:color="#FF0B1220"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Borde sutil (1dp, blanco 10 % opacidad) ── -->
    <path
        android:pathData="M34,18 L74,18 Q90,18 90,34 L90,74 Q90,90 74,90 L34,90 Q18,90 18,74 L18,34 Q18,18 34,18 Z"
        android:fillColor="#00000000"
        android:strokeColor="#1AFFFFFF"
        android:strokeWidth="1" />

    <!-- ── Chart icon (coordenadas safe-zone 18–90) ── -->

    <!-- Círculo exterior semitransparente (cx=54, cy=54, r=25) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M29,54 A25,25 0,1,0 79,54 A25,25 0,1,0 29,54"
        android:strokeColor="#805E8BFF"
        android:strokeWidth="1.9" />

    <!-- Línea de tendencia -->
    <path
        android:fillColor="#00000000"
        android:pathData="M40,65 L49,54 L59,59 L70,41"
        android:strokeColor="#7DA5FF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2.4" />

    <!-- Puntos -->
    <path android:fillColor="#7DA5FF"
        android:pathData="M40,65 m-2.4,0 a2.4,2.4 0,1,0 4.8,0 a2.4,2.4 0,1,0 -4.8,0" />
    <path android:fillColor="#7DA5FF"
        android:pathData="M49,54 m-2.4,0 a2.4,2.4 0,1,0 4.8,0 a2.4,2.4 0,1,0 -4.8,0" />
    <path android:fillColor="#7DA5FF"
        android:pathData="M59,59 m-2.4,0 a2.4,2.4 0,1,0 4.8,0 a2.4,2.4 0,1,0 -4.8,0" />
    <path android:fillColor="#5E8BFF"
        android:pathData="M70,41 m-3.1,0 a3.1,3.1 0,1,0 6.2,0 a3.1,3.1 0,1,0 -6.2,0" />

    <!-- Flecha hacia arriba -->
    <path
        android:fillColor="#00000000"
        android:pathData="M65,41 L70,37 L75,41"
        android:strokeColor="#5E8BFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="1.7" />

</vector>
